# =============================================
# Condense Playbook — Environment Variables
# =============================================
# Copy this file to .env and fill in your keys.
# NEVER commit .env to version control.

# --- Firebase ---
# Get these from: https://console.firebase.google.com
# Project Settings → Your Apps → Web App → Config
VITE_FIREBASE_API_KEY=REPLACE_WITH_YOUR_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=condense-salesplaybook.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=condense-salesplaybook
VITE_FIREBASE_STORAGE_BUCKET=condense-salesplaybook.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=1034577598966
VITE_FIREBASE_APP_ID=1:1034577598966:web:c7ffd9b44276de803f4fd7

# --- AI Bot (Gemini) ---
# Get from: https://aistudio.google.com/app/apikey
# NOTE: In production, add GEMINI_API_KEY (no VITE_ prefix) to Vercel env vars.
#       The api/chat.ts proxy will read it server-side so it's never exposed.
GEMINI_API_KEY=your_gemini_api_key

# --- Admin Password ---
# This is required to access the /admin route in the app
VITE_ADMIN_PASSWORD=choose_a_strong_password

